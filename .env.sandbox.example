# King Sparkon Tracker backend sandbox environment
# Copy this file to .env.sandbox locally. Do not commit real secret values.

SPRING_PROFILES_ACTIVE=sandbox

# Stripe sandbox keys
STRIPE_SECRET_KEY=
STRIPE_API_KEY=${STRIPE_SECRET_KEY}
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Ticket sandbox checkout URLs
TICKETS_CHECKOUT_SUCCESS_URL=http://localhost:3000/tickets/my-tickets?stripe=success
TICKETS_CHECKOUT_CANCEL_URL=http://localhost:3000/tickets?stripe=cancelled

# Ticket business settings
TICKETS_WITHDRAWAL_FEE_PERCENT=5.00
TICKETS_WITHDRAWAL_MINIMUM_ZAR=100.00
TICKETS_PROMOTION_PRICE_ZAR=1500.00

# Local database example
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_URL=jdbc:postgresql://localhost:5432/king_sparkon_tracker
