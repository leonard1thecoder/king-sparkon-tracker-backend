# King Sparkon Tracker Backend - Cloud Run environment template
# Copy these names into Cloud Run env vars / GitHub Actions variables.
# Do not commit real secrets. Keep secrets in Google Secret Manager.

# Runtime
SPRING_PROFILES_ACTIVE=prod,redis
SERVER_PORT=8080
RATE_LIMIT_BACKEND=redis

# Database
SUPABASE_DB_URL=jdbc:postgresql://YOUR_DB_HOST:6543/postgres?prepareThreshold=0
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
# Secret Manager: SUPABASE_DB_PASSWORD

# Security
# Secret Manager: JWT_SECRET
JWT_EXPIRATION_MINUTES=60
PASSWORD_RESET_EXPIRATION_MINUTES=30

# Frontend / CORS
CORS_ALLOWED_ORIGINS=https://YOUR_FRONTEND_DOMAIN
CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With
CORS_EXPOSED_HEADERS=Authorization
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE_SECONDS=3600
FRONTEND_RESET_PASSWORD_URL=https://YOUR_FRONTEND_DOMAIN/reset-password
FRONTEND_EMAIL_VERIFICATION_URL=https://YOUR_FRONTEND_DOMAIN/verify-email
FRONTEND_LOGIN_URL=https://YOUR_FRONTEND_DOMAIN/login

# Stripe
# Secret Manager: STRIPE_SECRET_KEY
# Secret Manager: STRIPE_WEBHOOK_SECRET
STRIPE_SUCCESS_URL=https://YOUR_FRONTEND_DOMAIN/dashboard/owner?billing=stripe-success
STRIPE_CANCEL_URL=https://YOUR_FRONTEND_DOMAIN/dashboard/owner?billing=stripe-cancelled

# PayPal
PAYPAL_BASE_URL=https://api-m.paypal.com
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
# Secret Manager: PAYPAL_CLIENT_SECRET
# Secret Manager: PAYPAL_WEBHOOK_ID
PAYPAL_RETURN_URL=https://YOUR_FRONTEND_DOMAIN/billing/return
PAYPAL_CANCEL_URL=https://YOUR_FRONTEND_DOMAIN/billing/cancel
PAYPAL_BILLING_PLUS_MONTHLY_PLAN_ID=
PAYPAL_BILLING_PLUS_YEARLY_PLAN_ID=
PAYPAL_BILLING_PRO_MONTHLY_PLAN_ID=
PAYPAL_BILLING_PRO_YEARLY_PLAN_ID=

# Mail / SMTP
APP_MAIL_ENABLED=true
APP_MAIL_FROM=no-reply@kingsparkon-tracker.com
CONTACT_NOTIFICATION_EMAIL=support@kingsparkon-tracker.com
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_SMTP_USERNAME
# Secret Manager: MAIL_PASSWORD
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_SMTP_CONNECTION_TIMEOUT_MS=5000
MAIL_SMTP_TIMEOUT_MS=5000
MAIL_SMTP_WRITE_TIMEOUT_MS=5000

# Twilio WhatsApp
TWILIO_WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
# Secret Manager: TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Redis / Memorystore
SPRING_DATA_REDIS_HOST=YOUR_REDIS_HOST
SPRING_DATA_REDIS_PORT=6379
# Secret Manager: SPRING_DATA_REDIS_PASSWORD
REDIS_TIMEOUT=2s

# Rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PUBLIC_AUTH_LIMIT=10
RATE_LIMIT_PUBLIC_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_PUBLIC_AUTH_RETRY_AFTER_SECONDS=60
RATE_LIMIT_FREE_TRIAL_LIMIT=30
RATE_LIMIT_FREE_TRIAL_WINDOW_SECONDS=60
RATE_LIMIT_FREE_TRIAL_RETRY_AFTER_SECONDS=30
RATE_LIMIT_PLUS_LIMIT=120
RATE_LIMIT_PLUS_WINDOW_SECONDS=60
RATE_LIMIT_PLUS_RETRY_AFTER_SECONDS=15
RATE_LIMIT_PRO_LIMIT=600
RATE_LIMIT_PRO_WINDOW_SECONDS=60
RATE_LIMIT_PRO_RETRY_AFTER_SECONDS=5

# Tips / withdrawals
TIPS_WITHDRAWAL_FEE_PERCENT=8.5
TIPS_WITHDRAWAL_MINIMUM_ZAR=1000
TIPS_WITHDRAWAL_HOLD_DAYS=7
TIPS_PAYPAL_ONBOARDING_URL=https://YOUR_FRONTEND_DOMAIN/dashboard/owner/paypal/onboarding
TIPS_WORKER_TIP_URL_TEMPLATE=https://YOUR_FRONTEND_DOMAIN/tips/workers/{workerId}
TRANSACTIONS_WITHDRAWAL_MINIMUM_ZAR=1000
TRANSACTIONS_WITHDRAWAL_HOLD_DAYS=7
TRANSACTIONS_WEBSITE_WITHDRAWAL_FEE_PERCENT=6.5
TRANSACTIONS_PAYPAL_ONBOARDING_URL=https://YOUR_FRONTEND_DOMAIN/dashboard/owner/transactions/paypal/onboarding

# Docs / Swagger
SPRINGDOC_API_DOCS_ENABLED=false
SPRINGDOC_SWAGGER_UI_ENABLED=false

# JVM
JAVA_OPTS=-XX:MaxRAMPercentage=75 -XX:+ExitOnOutOfMemoryError
